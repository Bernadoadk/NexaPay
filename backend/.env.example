# Neon (prod) : utiliser l'URL "pooled" + ?sslmode=require
# Ex. postgresql://user:pass@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/nexapay"
JWT_SECRET="change-this-secret-in-production"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Email (SMTP) — pour l'envoi des codes OTP et des devis
# Gmail : activer la 2FA puis créer un "mot de passe d'application" (16 caractères).
# Ne pas utiliser le mot de passe principal du compte Google.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="votre@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
# Optionnel — expéditeur affiché (défaut : "NexaPay" <SMTP_USER>)
SMTP_FROM="NexaPay <votre@gmail.com>"

# Google OAuth
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"

# Apple Sign-In
APPLE_CLIENT_ID="com.nexapay.app"

# Cloudinary (upload logos)
CLOUDINARY_CLOUD_NAME="xxxx"
CLOUDINARY_API_KEY="xxxx"
CLOUDINARY_API_SECRET="xxxx"

# Fedapay (encaissements Mobile Money + carte, reversements Mobile Money)
FEDAPAY_ENV="sandbox"
FEDAPAY_SECRET_KEY="xxxx"
# Secret du webhook FedaPay (wh_sandbox_... ou wh_live_...).
# FedaPay envoie automatiquement la signature dans X-FEDAPAY-SIGNATURE.
FEDAPAY_WEBHOOK_SHARED_SECRET="wh_sandbox_xxxx"

# OpenAI (fonctions IA — crédits)
OPENAI_API_KEY="sk-xxxx"
OPENAI_MODEL="gpt-4o-mini"

# Optionnel : catalogue complet des familles via l'API officielle Google Fonts.
GOOGLE_FONTS_API_KEY=""
